# ====================================
# LLM Provider 配置
# ====================================
# 可选值: openai | anthropic | deepseek | xiaomi | custom
LLM_PROVIDER=openai

# API Key（通用，也兼容 ANTHROPIC_API_KEY / OPENAI_API_KEY）
LLM_API_KEY=sk-74426d263a834c95ac49ec330cf3dad

# 模型名称（留空使用 provider 预设默认值）
LLM_MODEL=deepseek-v4-pro

# 自定义 Base URL（仅 openai/deepseek/xiaomi/custom 有效）
# LLM_BASE_URL=https://api.deepseek.com/v1

# 自定义 headers（JSON 格式）
# LLM_EXTRA_HEADERS={"X-Custom-Header": "value"}

# ====================================
# Provider 快速参考
# ====================================
# Anthropic:   LLM_PROVIDER=anthropic  LLM_API_KEY=sk-ant-xxx
# DeepSeek:    LLM_PROVIDER=deepseek   LLM_API_KEY=sk-xxx
# Xiaomi:      LLM_PROVIDER=xiaomi     LLM_API_KEY=sk-xxx
# OpenAI:      LLM_PROVIDER=openai     LLM_API_KEY=sk-xxx

# ====================================
# Agent 配置
# ====================================
AGENT_MAX_STEPS=20
AGENT_MAX_CONTEXT_TOKENS=8000
AGENT_COMPACT_THRESHOLD=0.75
